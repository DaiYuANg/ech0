# max_records = 100
# timeout_ms = 5000

# [[broker.mirror_sinks]]
# name = "orders-mirror"
# topic = "orders"
# target_topic = "orders"
# partition = 0
# consumer = "orders-mirror"
# target_admin_url = "http://127.0.0.1:19091"
# interval_secs = 5
# max_records = 100
# timeout_ms = 5000

# [[broker.database_outboxes]]
# name = "orders-outbox"
# topic = "orders"
# driver_name = "postgres"
# dsn = "postgres://user:pass@127.0.0.1:5432/app?sslmode=disable"
# query = "select id, topic, partition, key, routing_key, payload from outbox where delivered_at is null order by id"
# mark_delivered_sql = "update outbox set delivered_at = now() where id = $1"
# interval_secs = 5
# max_records = 100

[admin]
enabled = true
bind_addr = "127.0.0.1:9091"

[storage]
segments_dir = "segments"
# "mmap" is experimental and only maps sealed segment files; active segments use pread.
segment_read_mode = "pread"
retention_cleanup_enabled = true
retention_cleanup_interval_secs = 30
compaction_cleanup_enabled = true
compaction_cleanup_interval_secs = 60
compaction_sealed_segment_batch = 2

[logging]
level = "info,broker=debug,store=debug"
format = "text"
enable_stdout = true
enable_file = true
directory = "logs"
file_prefix = "ech0"
rotation = "daily"
max_files = 14
ansi = true

[raft]
bind_addr = "127.0.0.1:3210"
metrics_interval_ms = 1000
heartbeat_interval_ms = 150
election_timeout_min_ms = 300
election_timeout_max_ms = 600
snapshot_max_chunk_size = 3145728

[[raft.cluster]]
node_id = 1
addr = "127.0.0.1:3210"

[discovery]
enabled = false
provider = "memberlist"
bind_addr = "127.0.0.1:7946"
bootstrap_expect = 1
join_timeout_ms = 10000
