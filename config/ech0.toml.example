# name = "orders-s3"
# topic = "orders"
# partition = 0
# consumer = "orders-s3"
# endpoint_url = "http://127.0.0.1:9000"
# bucket = "archive"
# prefix = "ech0"
# region = "us-east-1"
# access_key_id = "change-me"
# secret_access_key = "change-me"
