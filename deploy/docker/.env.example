# Runtime image base: debian | alpine
ECH0_BASE_IMAGE=debian

# Single-node compose host ports
ECH0_SINGLE_BROKER_PORT=9090
ECH0_SINGLE_ADMIN_PORT=9091
ECH0_SINGLE_RAFT_PORT=3210

# Cluster compose host ports (node1)
ECH0_NODE1_BROKER_PORT=19090
ECH0_NODE1_ADMIN_PORT=19091
ECH0_NODE1_RAFT_PORT=13210

# Cluster compose host ports (node2)
ECH0_NODE2_BROKER_PORT=29090
ECH0_NODE2_ADMIN_PORT=29091
ECH0_NODE2_RAFT_PORT=23210

# Cluster compose host ports (node3)
ECH0_NODE3_BROKER_PORT=39090
ECH0_NODE3_ADMIN_PORT=39091
ECH0_NODE3_RAFT_PORT=33210
