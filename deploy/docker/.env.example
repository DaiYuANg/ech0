# Runtime image base for local Dockerfile builds: debian | alpine
ECH0_BASE_IMAGE=debian

# Image used by release compose files. Alpine is the default release image.
# Debian images are published with the -debian suffix, for example ghcr.io/daiyuang/ech0:latest-debian.
ECH0_IMAGE=ghcr.io/daiyuang/ech0:latest

# Local image tags used by build compose files.
ECH0_SINGLE_IMAGE=ech0:single-local
ECH0_CLUSTER_IMAGE=ech0:cluster-local

# Cluster data root. Override for clean benchmark runs without deleting ./data/cluster.
ECH0_CLUSTER_DATA_ROOT=./data/cluster

# HashiCorp raft commit timeout in milliseconds. Lower values reduce low-load write latency but may reduce batching.
ECH0_RAFT_COMMIT_TIMEOUT_MS=50

# Single-node compose host ports
ECH0_SINGLE_BROKER_PORT=9090
ECH0_SINGLE_ADMIN_PORT=9091
ECH0_SINGLE_RAFT_PORT=3210

# Cluster compose host ports (node1)
ECH0_NODE1_BROKER_PORT=19090
ECH0_NODE1_ADMIN_PORT=19091
ECH0_NODE1_RAFT_PORT=13210

# Cluster compose host ports (node2)
ECH0_NODE2_BROKER_PORT=29090
ECH0_NODE2_ADMIN_PORT=29091
ECH0_NODE2_RAFT_PORT=23210

# Cluster compose host ports (node3)
ECH0_NODE3_BROKER_PORT=39090
ECH0_NODE3_ADMIN_PORT=39091
ECH0_NODE3_RAFT_PORT=33210
